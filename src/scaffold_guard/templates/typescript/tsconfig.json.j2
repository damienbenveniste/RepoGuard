{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "lib": ["ES2022"],
    "rootDir": ".",
    "strict": {{ typescript_strict_enabled }},
{% if use_typescript_strict %}
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
{% endif %}
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"{% if use_vitest %}, "tests/**/*.ts", "vitest.config.ts"{% endif %}]
}
